@page "/"

<PageTitle>Backlog Buster</PageTitle>

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">🚀 Backlog Buster</h1>
        <p class="lead text-muted">A suite of tools to help remote teams asynchronously mass size, prioritise, and keep the backlog up to date.</p>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">📋</div>
                    <h5 class="card-title">Backlog</h5>
                    <p class="card-text text-muted">View, add, and manage all your backlog items in one place.</p>
                    <a href="/backlog" class="btn btn-primary mt-2">Open Backlog</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">⚖️</div>
                    <h5 class="card-title">Sizerator</h5>
                    <p class="card-text text-muted">Rank your backlog items by dragging them into an ordered list to set priorities.</p>
                    <a href="/sizerator" class="btn btn-primary mt-2">Open Sizerator</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">🗳️</div>
                    <h5 class="card-title">Priority Voting</h5>
                    <p class="card-text text-muted">Let the whole team vote on what matters most, asynchronously and without meetings.</p>
                    <span class="badge bg-secondary mt-2">Coming Soon</span>
                </div>
            </div>
        </div>
    </div>
</div>
